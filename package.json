{
  "name": "tachikoma-mcp",
  "displayName": "Tachikoma MCP Server",
  "description": "Code intelligence \u2014 semantic search, impact analysis, rename refactoring, wiki generation. Powered by tachikoma knowledge graph.",
  "version": "1.3.0",
  "publisher": "Tachikoma",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoliChrys/tachikoma-mcp"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-intelligence",
    "knowledge-graph",
    "chat-participant"
  ],
  "extensionDependencies": [
    "Tachikoma.tachikoma-collab"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServers": {
      "tachikoma": {
        "command": "npx",
        "args": [
          "-y",
          "tachikoma-mcp-server"
        ],
        "env": {}
      }
    },
    "commands": [
      {
        "command": "tachikoma-mcp.menu",
        "title": "Tachikoma MCP: Show Menu"
      },
      {
        "command": "tachikoma-mcp.reconnect",
        "title": "Tachikoma MCP: Reconnect"
      },
      {
        "command": "tachikoma-mcp.showLogs",
        "title": "Tachikoma MCP: Show Logs"
      },
      {
        "command": "tachikoma-mcp.enableMcp",
        "title": "Tachikoma MCP: Enable VS Code MCP support"
      }
    ]
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.0"
  }
}
